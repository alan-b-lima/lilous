    "colors": {
        "activityBar.background": "#3d435f",
        "activityBar.foreground": "#a498cF",
        "activityBarBadge.background": "#a498cF",
        "activityBarBadge.foreground": "#ffffff",
        "badge.background": "#a498cF",
        "button.background": "#705697",
        "dropdown.background": "#2d3143",
        "dropdown.foreground": "#decffd",
        "editor.background": "#2d3143",
        "editor.findMatchBackground": "#ff91008f",
        "editor.findMatchHighlightBackground": "#8a8a8a63",
        "editor.lineHighlightBackground": "#3a3f53",
        "editor.selectionBackground": "#3a3f53",
        "editorCursor.foreground": "#d2c2f5",
        "editorGroupHeader.tabsBackground": "#3d435f",
        "editorIndentGuide.background1": "#00000000",
        "editorInlayHint.background": "#70569755",
        "editorInlayHint.parameterBackground": "#70569755",
        "editorInlayHint.typeBackground": "#70569755",
        "editorLineNumber.activeForeground": "#a498cF",
        "editorLineNumber.foreground": "#705697",
        "editorSuggestWidget.background": "#2d3143",
        "editorSuggestWidget.border": "#705697",
